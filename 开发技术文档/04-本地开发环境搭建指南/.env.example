# ============================================================
# 知微（ziwi）SaaS — 本地开发环境变量模板
# 复制此文件为 .env，按需修改
# ============================================================

# ---------- 应用基础配置 ----------
APP_NAME=ziwi
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change_me_in_production_use_a_random_64_char_string
APP_HOST=0.0.0.0
APP_PORT=8000
APP_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# ---------- 数据库（PostgreSQL + TimescaleDB） ----------
# 注：Docker Compose 环境使用 PgBouncer 地址（pgbouncer:6432）
#     本地直接连接使用 postgres:5432
DB_HOST=pgbouncer
DB_PORT=6432
DB_NAME=ziwi
DB_USER=ziwi
DB_PASSWORD=ziwi_dev_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# ---------- 连接池直连（用于 Alembic 迁移） ----------
DB_DIRECT_HOST=postgres
DB_DIRECT_PORT=5432
DB_DIRECT_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_DIRECT_HOST}:${DB_DIRECT_PORT}/${DB_NAME}

# ---------- Redis（缓存 + Session + Pub/Sub） ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ziwi_redis_password
REDIS_DB=0
REDIS_SESSION_DB=1
REDIS_CACHE_DB=2

# ---------- MinIO（对象存储） ----------
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=ziwi_minio_admin
MINIO_SECRET_KEY=ziwi_minio_password
MINIO_BUCKET=ziwi-files
MINIO_PUBLIC_BUCKET=ziwi-public
MINIO_REGION=cn-east-1

# ---------- EMQX（MQTT Broker） ----------
MQTT_BROKER_HOST=emqx
MQTT_BROKER_PORT=1883
MQTT_WS_PORT=8083
MQTT_USERNAME=ziwi
MQTT_PASSWORD=ziwi_mqtt_password
MQTT_CLIENT_ID_PREFIX=ziwi_backend_

# ---------- JWT / 认证 ----------
JWT_SECRET_KEY=change_me_jwt_secret_32_chars_min
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- 企业微信 ----------
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# ---------- 钉钉 ----------
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=

# ---------- 短信（阿里云 SMS） ----------
SMS_ACCESS_KEY_ID=
SMS_ACCESS_KEY_SECRET=
SMS_SIGN_NAME=知微制造
SMS_TEMPLATE_CODE=

# ---------- 邮件（SMTP） ----------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@ziwi.cn
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_NAME=知微制造

# ---------- 功能开关 ----------
# 参见 feature_flags.json
FEATURE__M01_PRODUCTION=true
FEATURE__M02_TPM=true
FEATURE__M03_QUALITY=true
FEATURE__M05_ANDON=true
FEATURE__M11_ENERGY=false
FEATURE__M12_IOT=true
FEATURE__M13_DASHBOARD=true

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_REQUEST_ID_HEADER=X-Request-Id

# ---------- 性能 ----------
API_RATE_LIMIT_PER_MINUTE=120
CIRCUIT_BREAKER_P95_THRESHOLD_MS=2000
CIRCUIT_BREAKER_ERROR_RATE_THRESHOLD=0.1
CIRCUIT_BREAKER_OPEN_DURATION_SECONDS=30

# ---------- 定时任务 ----------
SCHEDULER_HEARTBEAT_INTERVAL_SECONDS=300
SCHEDULER_ANDON_ESCALATION_INTERVAL_SECONDS=60
SCHEDULER_LICENSE_WARNING_HOUR=8
SCHEDULER_DATA_COMPRESSION_HOUR=2
