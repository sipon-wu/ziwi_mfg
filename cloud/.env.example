# In docker-compose network, reference the Postgres service by name "db:5432",
# NOT "localhost" — inside the container localhost points to the container itself.
CLOUD_DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/cloud_idp
CLOUD_JWT_ACCESS_EXPIRE_MINUTES=30
CLOUD_JWT_REFRESH_EXPIRE_DAYS=7
CLOUD_KEY_DIR=keys
CLOUD_CORS_ORIGINS=https://cloud.ziwi.cn
CLOUD_DEBUG=false
