# Heartbeat Service Configuration
# Copy to .env and adjust as needed

# API Key for authenticating heartbeat clients
HEARTBEAT_API_KEY=changeme-dev-key

# SQLite database path (relative to app/ or absolute)
HEARTBEAT_DATABASE_PATH=data/heartbeat.db

# Service port
HEARTBEAT_PORT=8091

# Heartbeat timeout: deployments not heard from in this many minutes are considered stale
HEARTBEAT_TIMEOUT_MINUTES=15

# Number of consecutive missed heartbeats before marking a deployment offline
HEARTBEAT_OFFLINE_THRESHOLD_MISSES=3

# Scheduler check interval in minutes
HEARTBEAT_CHECK_INTERVAL_MINUTES=5

# License expiry warning thresholds in days
HEARTBEAT_LICENSE_WARN_DAYS=30
HEARTBEAT_LICENSE_CRITICAL_DAYS=7
