# Ziwi Heartbeat Client — environment configuration
# Copy to .env and fill in. All keys are prefixed with HEARTBEAT_.

# API key shared with the heartbeat service (NEVER commit the real value)
HEARTBEAT_API_KEY=your-secure-api-key

# Service endpoint (default: https://heartbeat.ziwi.cn)
HEARTBEAT_SERVER_URL=https://heartbeat.ziwi.cn

# Deployment identity
HEARTBEAT_DEPLOYMENT_ID=mfg-shanghai-01
HEARTBEAT_TENANT_ID=mfg_tenant_shanghai
HEARTBEAT_PRODUCT=mfg
HEARTBEAT_VERSION=1.5.0

# License (ISO 8601, required only on FIRST report of a new deployment)
HEARTBEAT_LICENSE_ISSUED_AT=2025-03-01T00:00:00Z
HEARTBEAT_LICENSE_EXPIRES_AT=2026-03-01T00:00:00Z

# Behaviour
HEARTBEAT_INTERVAL_SECONDS=3600
HEARTBEAT_MAX_RETRIES=3
HEARTBEAT_RETRY_BACKOFF_SECONDS=10
HEARTBEAT_REQUEST_TIMEOUT=10
