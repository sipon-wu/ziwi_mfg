APP_NAME=ziwi
APP_ENV=development
APP_DEBUG=true
APP_SECRET_KEY=change_me_in_production_32_chars_min
APP_CORS_ORIGINS=*

# ── 数据库（默认 sqlite；设 DB_DRIVER=postgresql 切换异步 PG）──
DB_DRIVER=sqlite
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ziwi
DB_USER=ziwi
DB_PASSWORD=ziwi_dev_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO_SQL=false

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=ziwi_redis_password
REDIS_DB=0

# ── cloud.ziwi.cn 统一 JWT 认证（RS256 非对称验签）──
CLOUD_JWKS_URL=https://cloud.ziwi.cn/api/v1/auth/public-key
CLOUD_JWKS_CACHE_TTL=3600
CLOUD_JWKS_FETCH_TIMEOUT=5.0
CLOUD_EXPECTED_ALGORITHM=RS256
CLOUD_CLOCK_SKEW_SECONDS=30

# ── [DEPRECATED] 以下本地 JWT 签发配置已不再使用（保留字段名避免下游报错）──
# JWT_SECRET_KEY=change_me_jwt_secret_32_chars_min
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── 私有部署心跳上报（heartbeat.ziwi.cn，接口契约 D.1 节）──
# 仅当 HEARTBEAT_API_KEY 与 HEARTBEAT_DEPLOYMENT_ID 均配置时，mfg 启动才会真正上报心跳（见 app/main.py 守卫）。
# 当前预发布可用 dev key：hb-dev-key-2026（服务端功能正常）；生产请替换为 cloud 签发 key。
# 新实例首次上报必带 license_issued_at / license_expires_at，否则服务端返回 400。
HEARTBEAT_SERVER_URL=https://heartbeat.ziwi.cn
HEARTBEAT_API_KEY=
HEARTBEAT_DEPLOYMENT_ID=
HEARTBEAT_TENANT_ID=
HEARTBEAT_PRODUCT=mfg
HEARTBEAT_VERSION=
HEARTBEAT_LICENSE_ISSUED_AT=
HEARTBEAT_LICENSE_EXPIRES_AT=
HEARTBEAT_INTERVAL_SECONDS=3600
HEARTBEAT_MAX_RETRIES=3
HEARTBEAT_RETRY_BACKOFF_SECONDS=10
HEARTBEAT_REQUEST_TIMEOUT=10

# ── 日志 ──
LOG_LEVEL=INFO
LOG_FORMAT=json
